<UserControl x:Class="RevitSyncService.UI.Views.LogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:RevitSyncService.UI.Converters">

    <UserControl.Resources>
        <conv:LogLevelToColorConverter x:Key="LogLevelToColor" />
    </UserControl.Resources>

    <DockPanel Margin="10,10,10,5">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="Обновить" Style="{StaticResource SecondaryButton}" 
                    Command="{Binding RefreshCommand}" Margin="0,0,8,0" />
            <Button Content="Очистить" Style="{StaticResource SecondaryButton}" 
                    Command="{Binding ClearCommand}" />
        </StackPanel>

        <ListBox x:Name="LogListBox"
         ItemsSource="{Binding LogEntries}"
         FontFamily="Consolas, Courier New"
         FontSize="12">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Display}" 
                               Foreground="{Binding Level, Converter={StaticResource LogLevelToColor}}"
                               TextWrapping="Wrap" Margin="4,2" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>