<Window x:Class="RevitSyncService.UI.Views.ProjectEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:RevitSyncService.UI.Converters"
        Style="{StaticResource DarkWindow}"
        Title="{Binding WindowTitle}" 
        Width="960" Height="880"
        MinWidth="500" MinHeight="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding WindowTitle}" Style="{StaticResource Header}" Margin="0,0,0,18" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <TextBlock Text="НАЗВАНИЕ ПРОЕКТА" Style="{StaticResource Label}" />
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" />

                <TextBlock Text="ТИП ИСТОЧНИКА" Style="{StaticResource Label}" />
                <ComboBox SelectedValue="{Binding SourceType}" SelectedValuePath="Tag" Margin="0,0,0,14">
                    <ComboBoxItem Content="Revit Server" Tag="RevitServer" />
                    <ComboBoxItem Content="Сетевая папка" Tag="NetworkFolder" />
                </ComboBox>

                <!-- Revit Server -->
                <Border Visibility="{Binding IsRevitServer, Converter={StaticResource BoolToVis}}"
                        Background="{StaticResource BgLightBrush}" 
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="14" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="НАСТРОЙКИ REVIT SERVER" Style="{StaticResource Label}" 
                                   FontWeight="SemiBold" Margin="0,0,0,10" />

                        <TextBlock Text="Сервер" Style="{StaticResource Label}" />
                        <ComboBox ItemsSource="{Binding AvailableServers}"
          SelectedItem="{Binding SelectedServer}" Margin="0,0,0,10">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="Путь к папке на сервере" Style="{StaticResource Label}" />
                        <DockPanel Margin="0,0,0,10">
                            <Button DockPanel.Dock="Right" Content="Обзор" 
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding BrowseServerFoldersCommand}"
                                    Padding="12,6" Margin="8,0,0,0" />
                            <TextBox Text="{Binding ServerFolderPath, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>

                        <TreeView ItemsSource="{Binding FolderTree}"
                          MaxHeight="200" Margin="0,0,0,5"
                          SelectedItemChanged="TreeView_SelectedItemChanged">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <TextBlock Text="{Binding Name}" Margin="2,1" />
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </StackPanel>
                </Border>

                <!-- Сетевая папка -->
                <Border Visibility="{Binding IsNetworkFolder, Converter={StaticResource BoolToVis}}"
                        Background="{StaticResource BgLightBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="14" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="СЕТЕВАЯ ПАПКА" Style="{StaticResource Label}" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="Обзор" 
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding BrowseNetworkFolderCommand}"
                                    Padding="12,6" Margin="8,0,0,0" />
                            <TextBox Text="{Binding NetworkFolderPath, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- Целевые папки -->
                <TextBlock Text="ПАПКА ДЛЯ RVT ФАЙЛОВ" Style="{StaticResource Label}" />
                <DockPanel Margin="0,0,0,10">
                    <Button DockPanel.Dock="Right" Content="📁" 
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding BrowseRvtPathCommand}"
                            Padding="10,6" Margin="8,0,0,0" />
                    <TextBox Text="{Binding RvtPath, UpdateSourceTrigger=PropertyChanged}" />
                </DockPanel>
                <TextBlock Text="ПАПКА ДЛЯ NWC ФАЙЛОВ" Style="{StaticResource Label}"  />
                <CheckBox Content="Создавать NWC файлы" IsChecked="{Binding CreateNwc}" Margin="0,0,0,8" />
                <DockPanel Margin="0,0,0,10">
                    <Button DockPanel.Dock="Right" Content="📁" 
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding BrowseNwcPathCommand}"
                            Padding="10,6" Margin="8,0,0,0"
                            IsEnabled="{Binding CreateNwc}"/>
                    <TextBox Text="{Binding NwcPath, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CreateNwc}"/>
                </DockPanel>



                <!-- Расписание -->
                <TextBlock Text="РАСПИСАНИЕ" Style="{StaticResource Label}" />
                <ComboBox SelectedValue="{Binding ScheduleType}" SelectedValuePath="Tag" Margin="0,0,0,10">
                    <ComboBoxItem Content="Еженедельно" Tag="Weekly" />
                    <ComboBoxItem Content="Раз в 2 недели" Tag="Biweekly" />
                    <ComboBoxItem Content="⏸ Приостановлен" Tag="Paused" />
                </ComboBox>

                <TextBlock Text="День недели" Style="{StaticResource Label}" />
                <ComboBox ItemsSource="{Binding DayNames}" SelectedIndex="{Binding DayOfWeek}" Margin="0,0,0,10" />

                <TextBlock Text="Время (HH:mm)" Style="{StaticResource Label}" />
                <TextBox Text="{Binding Time, UpdateSourceTrigger=PropertyChanged}" 
                         Width="120" HorizontalAlignment="Left" Margin="0,0,0,10" />

                <TextBlock Text="ИСКЛЮЧЁННЫЕ ПАПКИ (через запятую)" Style="{StaticResource Label}" />
                <TextBox Text="{Binding ExcludedFolders, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />

            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Сохранить" Style="{StaticResource PrimaryButton}" 
                    Command="{Binding SaveCommand}" Margin="0,0,10,0" IsDefault="True" />
            <Button Content="Отмена" Style="{StaticResource SecondaryButton}" 
                    Command="{Binding CancelCommand}" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>