<Window x:Class="RevitSyncService.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:RevitSyncService.UI.Views"
        Style="{StaticResource DarkWindow}"
        Title="RevitSync Service" 
        Width="950" Height="620"
        MinWidth="750" MinHeight="450"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/MPFileExport.ico"
>

    <Grid Margin="10 10 10 15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <DockPanel Grid.Row="0" Margin="0,0,0,5">
            <TextBlock Text="МОСПРОЕКТ" Style="{StaticResource Header}" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="⚙ Настройки" Style="{StaticResource SecondaryButton}"
                Padding="12,6" FontSize="12" Margin="0,0,8,0"
                Click="OnSettingsClick" />
                <Button Content="Выход" Style="{StaticResource DangerButton}"
                Padding="12,6" FontSize="12"
                Click="OnExitClick" />
            </StackPanel>
        </DockPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="Проекты">
                <views:ProjectsView DataContext="{Binding ProjectsVM}" />
            </TabItem>
            <TabItem Header="Лог">
                <views:LogView DataContext="{Binding LogVM}" />
            </TabItem>
        </TabControl>
    </Grid>
</Window>