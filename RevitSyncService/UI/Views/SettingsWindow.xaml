<Window x:Class="RevitSyncService.UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:RevitSyncService.UI.Converters"
        Style="{StaticResource DarkWindow}"
        Title="Подключение к базе данных"
        Width="420" Height="680"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Настройки базы данных"
                   Style="{StaticResource Header}" Margin="0,0,0,20" />

        <StackPanel Grid.Row="1">
            <TextBlock Text="ХОСТ" Style="{StaticResource Label}" />
            <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />

            <TextBlock Text="ПОРТ" Style="{StaticResource Label}" />
            <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" 
                     Width="100" HorizontalAlignment="Left" Margin="0,0,0,10" />

            <TextBlock Text="БАЗА ДАННЫХ" Style="{StaticResource Label}" />
            <TextBox Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />

            <TextBlock Text="ПОЛЬЗОВАТЕЛЬ" Style="{StaticResource Label}" />
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />

            <TextBlock Text="ПАРОЛЬ" Style="{StaticResource Label}" />
            <PasswordBox x:Name="PasswordBox" Margin="0,0,0,16"
                         Padding="10,8" FontSize="13"
                         PasswordChanged="PasswordBox_PasswordChanged" />

            <!-- Результат теста -->
            <Border Background="{StaticResource BgLightBrush}"
        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
        CornerRadius="6" Padding="12,8"
        Margin="0,8,0,0">
                <TextBlock Text="{Binding TestResult}" TextWrapping="Wrap"
               Foreground="{Binding TestResultColor}" FontSize="12" />
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Проверить" Style="{StaticResource SecondaryButton}"
        Command="{Binding TestCommand}"
        Margin="0,0,8,0" />
            <Button Content="Сохранить" Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveCommand}" Margin="0,0,8,0" />
            <Button Content="Отмена" Style="{StaticResource SecondaryButton}"
                    Command="{Binding CancelCommand}" />
        </StackPanel>
    </Grid>
</Window>